# ── LinguaPlay — Variables d'environnement ────────────────────────────────────

JWT_SECRET=change-me-in-production
ALLOWED_ORIGINS=*
RATE_LIMIT_PER_HOUR=10
MAX_FILE_SIZE_MB=500
DEV_MODE=true

# ── Acceptation termes Coqui CPML ─────────────────────────────────────────────
# OBLIGATOIRE pour eviter le crash "EOF when reading a line" dans le worker.
# En definissant cette variable a 1, vous acceptez les termes non-commerciaux
# de la Coqui Public Model License pour usage academique.
# Ref : https://coqui.ai/cpml.txt
COQUI_TOS_AGREED=1

# ── Moteur TTS ────────────────────────────────────────────────────────────────
XTTS_ENABLED=true

# HF_TOKEN optionnel (pas requis, poids telecharges via hf-mirror.com)
HF_TOKEN=

# Variables legacy
COSYVOICE_ENABLED=false
OPENVOICE_ENABLED=false